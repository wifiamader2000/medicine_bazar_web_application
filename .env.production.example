# ==============================================================================
# Medicine Bazar MERN V2/V3 Backend Production Environment Configuration
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file to '.env' (or '.env.production') on your production server.
# 2. Fill in all secure credentials, secrets, and database connection strings.
# 3. Ensure this file is NEVER committed to your git repository or exposed publicly.
# ==============================================================================

# Server Runtime Settings
NODE_ENV=production
PORT=5050
HOST=0.0.0.0

# CRITICAL SECURITY SECRETS (Generate long, random strings for production!)
# Example command to generate: openssl rand -hex 32
SESSION_SECRET=YOUR_SECURE_LONG_PRODUCTION_SESSION_SECRET_HERE
JWT_SECRET=YOUR_SECURE_LONG_PRODUCTION_JWT_SECRET_HERE

# Database Storage Engine Selection
# Supported: 'mongodb' or 'json' (highly recommend 'mongodb' for production)
DB_DRIVER=mongodb

# MongoDB Connection String (Required if DB_DRIVER=mongodb)
# Format: mongodb://[username:password@]host[:port]/database[?options]
MONGO_URI=mongodb://127.0.0.1:27017/medicine_bazar

# PostgreSQL Configuration (Optional: for future v3 migration roadmap)
DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medicine_bazar
POSTGRES_USER=mb_admin
POSTGRES_PASSWORD=YOUR_SECURE_POSTGRES_PASSWORD_HERE

# File Upload / Storage Configuration
# The directory where uploaded prescriptions are securely stored
UPLOAD_DIR=uploads
# File size limit (e.g. 10MB in bytes = 10 * 1024 * 1024)
MAX_FILE_SIZE=10485760

# Search Provider Configuration (Local or Cloud)
# 'local' uses the optimized weighted regex fuzzy engine
SEARCH_PROVIDER=local

# ==============================================================================
# FUTURE SYSTEM INTEGRATIONS (Uncomment and populate when completing v3 rollouts)
# ==============================================================================

# SMS Provider Integration (For prescription alerts/order updates)
SMS_PROVIDER=disabled
SMS_API_KEY=
SMS_SENDER_ID=

# SMTP/Email Server Configuration (For customer invoicing & password resets)
EMAIL_PROVIDER=disabled
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# WhatsApp Configuration
WHATSAPP_SUPPORT_NUMBER=8801602444532

# OAuth Social Authentication
# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# FACEBOOK_APP_ID=your_facebook_app_id_here
# FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# SSLCommerz / Mobile Financial Services Gateway Integrations
# SSLCOMMERZ_STORE_ID=your_sslcommerz_store_id
# SSLCOMMERZ_STORE_PASS=your_sslcommerz_store_password
# BKASH_APP_KEY=your_bkash_app_key
# BKASH_APP_SECRET=your_bkash_app_secret
# BKASH_USERNAME=your_bkash_username
# BKASH_PASSWORD=your_bkash_password
# NAGAD_MERCHANT_ID=your_nagad_merchant_id
# NAGAD_MERCHANT_KEY=your_nagad_merchant_private_key

# Secure Offsite Cloud Backups (For daily DB dumps)
# BACKUP_PROVIDER=s3
# S3_BUCKET=medicine-bazar-backups-prod
# S3_REGION=ap-southeast-1
# S3_ACCESS_KEY=your_aws_access_key_id
# S3_SECRET_KEY=your_aws_secret_access_key
\n# PAYMENT GATEWAYS\nBKASH_ENABLED=false\nBKASH_BASE_URL=\nBKASH_APP_KEY=\nBKASH_APP_SECRET=\nBKASH_USERNAME=\nBKASH_PASSWORD=\n\nNAGAD_ENABLED=false\nNAGAD_BASE_URL=\nNAGAD_MERCHANT_ID=\nNAGAD_MERCHANT_PRIVATE_KEY=\nNAGAD_PUBLIC_KEY=\n\nSSLCOMMERZ_ENABLED=false\nSSLCOMMERZ_STORE_ID=\nSSLCOMMERZ_STORE_PASSWORD=\nSSLCOMMERZ_IS_LIVE=false\n\nPAYMENT_CALLBACK_BASE_URL=
