# Medicine Bazar Environment Configuration
# Copy to .env and fill in values

# Server
NODE_ENV=development
PORT=5050
HOST=0.0.0.0
SESSION_SECRET=change-this-to-a-random-secret
JWT_SECRET=change-this-to-a-jwt-secret

# Database (production)
DB_TYPE=json
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=medicine_bazar
# DB_USER=mb_admin
# DB_PASSWORD=change-this

# Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# SMS Provider (future)
# SMS_PROVIDER=
# SMS_API_KEY=
# SMS_SENDER_ID=

# Email (future)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@medicinebazar.com

# OAuth (future)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# Payment Gateway (future)
# SSLCOMMERZ_STORE_ID=
# SSLCOMMERZ_STORE_PASS=
# BKASH_APP_KEY=
# BKASH_APP_SECRET=
# NAGAD_MERCHANT_ID=
# NAGAD_MERCHANT_KEY=

# Cloud Backup (future)
# BACKUP_PROVIDER=
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
