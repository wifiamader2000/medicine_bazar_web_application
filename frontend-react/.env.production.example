# ==============================================================================
# Medicine Bazar MERN V2/V3 Frontend Production Environment Configuration
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file to '.env' inside the 'frontend-react' directory before building.
# 2. Update the VITE_API_BASE_URL to point to your live backend domain or subdomain.
# 3. Compile the production bundles using 'npm run build:react'.
# ==============================================================================

# Backend API Root URL (Must be accessible from the client's browser)
# Replace with your actual live domain (e.g. HTTPS is highly recommended in production!)
VITE_API_BASE_URL=https://medicinebazar.com.bd/api/v1

# Note: If running staging or testing behind a subdomain:
# VITE_API_BASE_URL=https://staging.medicinebazar.com.bd/api/v1
